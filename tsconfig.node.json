{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": true,
        "outDir": "./out",
        "declaration": true,
        "composite": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "types": [
            "node"
        ]
    },
    "include": [
        "electron/**/*"
    ]
}